function isWeekendOrHoliday(year, month, day, holidays) {
  const dow = new Date(year, month - 1, day).getDay();
  return dow === 0 || dow === 6 || (holidays instanceof Set && holidays.has(day));
}

function getDayOfWeek(year, month, day) {
  return new Date(year, month - 1, day).getDay();
}

function isOff(duty) {
  return OFF_DUTIES.has(duty || '');
}

function isWork(duty) {
  return WORK_DUTIES.has(duty || '');
}

function isNight(duty) {
  return NIGHT_DUTIES.has(duty);
}

function isRecovery(duty) {
  return RECOVERY_DUTIES.has(duty);
}

// 자동 배정된 민감한 듀티(나이트, 특수 오프)를 알고리즘 수정에서 보호하는 함수
function isFixedDuty(duty) {
  if (!duty) return false;
  if (isNight(duty) || duty === DUTY.N_FULL) return true;
  if (isOff(duty) && duty !== DUTY.OFF) return true;
  if (isRecovery(duty)) return true;
  if (duty === DUTY.EDU || duty === DUTY.EDU_R) return true;
  if (duty === DUTY.D9 || duty === DUTY.D10) return true;  // 주말 특수 듀티 보호
  return false;
}

function getSlot(sched, nurseIdx, d, prevHistory, totalDays) {
  if (d >= 0 && d < totalDays) return sched[nurseIdx][d] || '';
  if (d < 0) {
    const histIdx = 7 + d;
    if (histIdx >= 0 && prevHistory[nurseIdx]) {
      return prevHistory[nurseIdx][histIdx] || '';
    }
  }
  return '';
}

function getTotalDays(yyyymm) {
  const year  = parseInt(yyyymm.slice(0, 4), 10);
  const month = parseInt(yyyymm.slice(4, 6), 10);
  return new Date(year, month, 0).getDate();
}

function getPrevMonth(yyyymm) {
  const year  = parseInt(yyyymm.slice(0, 4), 10);
  const month = parseInt(yyyymm.slice(4, 6), 10);
  const prev  = new Date(year, month - 2, 1);
  return `${prev.getFullYear()}${String(prev.getMonth() + 1).padStart(2, '0')}`;
}

function getNextMonth(yyyymm) {
  const year  = parseInt(yyyymm.slice(0, 4), 10);
  const month = parseInt(yyyymm.slice(4, 6), 10);
  const next  = new Date(year, month, 1);
  return `${next.getFullYear()}${String(next.getMonth() + 1).padStart(2, '0')}`;
}

function getOrCreateSheet(ss, name) {
  return ss.getSheetByName(name) || ss.insertSheet(name);
}

function recreateSheet(ss, name) {
  const existing = ss.getSheetByName(name);
  if (existing) ss.deleteSheet(existing);
  return ss.insertSheet(name);
}

function styleHeader(range, bgColor) {
  range
    .setFontWeight('bold')
    .setBackground(bgColor || '#4A90D9')
    .setFontColor('#FFFFFF')
    .setHorizontalAlignment('center');
}

function colToLetter(col) {
  let letter = '';
  while (col > 0) {
    const rem = (col - 1) % 26;
    letter = String.fromCharCode(65 + rem) + letter;
    col = Math.floor((col - 1) / 26);
  }
  return letter;
}

function normalize(val) {
  if (val === null || val === undefined) return '';
  return String(val).trim();
}

function argMin(arr) {
  let minVal = Infinity, minIdx = -1;
  arr.forEach((v, i) => { if (v < minVal) { minVal = v; minIdx = i; } });
  return minIdx;
}

