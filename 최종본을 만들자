function menuPrepare() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const ui = SpreadsheetApp.getUi();

  const yearResp = ui.prompt('📅 근무표 대상 년도 입력', '4자리 년도를 입력하세요. (예: 2025)', ui.ButtonSet.OK_CANCEL);
  if (yearResp.getSelectedButton() !== ui.Button.OK) { ui.alert('취소했습니다.'); return; }
  const yearVal = yearResp.getResponseText().trim();
  if (!/^\d{4}$/.test(yearVal)) { ui.alert('❌ 년도 형식 오류\n4자리 숫자로 입력해 주세요. (예: 2025)'); return; }

  const monthResp = ui.prompt('📅 근무표 대상 월 입력', '월을 입력하세요. (예: 8 또는 08)', ui.ButtonSet.OK_CANCEL);
  if (monthResp.getSelectedButton() !== ui.Button.OK) { ui.alert('취소했습니다.'); return; }
  const monthVal = monthResp.getResponseText().trim().padStart(2, '0');
  if (!/^(0[1-9]|1[0-2])$/.test(monthVal)) { ui.alert('❌ 월 형식 오류\n1~12 사이 숫자로 입력해 주세요.'); return; }

  const yyyymm    = yearVal + monthVal;
  const year      = parseInt(yearVal, 10);
  const month     = parseInt(monthVal, 10);
  const totalDays = getTotalDays(yyyymm);

  const holidaySheet = getOrCreateSheet(ss, SHEET.HOLIDAYS);
  _buildHolidaySheet(holidaySheet, yyyymm);

  const prevSheet = getOrCreateSheet(ss, SHEET.PREV_SCHED);
  if (prevSheet.getLastRow() === 0) {
    prevSheet.getRange('A1').setValue('← 전달 결과표_YYYYMM 시트 내용을 이 시트에 복사-붙여넣기 하세요.');
    prevSheet.getRange('A1').setFontColor('#888888').setFontStyle('italic');
  }

  const nurseSheet = getOrCreateSheet(ss, SHEET.NURSES);
  if (nurseSheet.getLastRow() === 0) {
    const headers = ['이름', '유형', '성별(여/남)', '팀(A~F)', '프리셉터 이름(신규만)'];
    nurseSheet.appendRow(headers);
    styleHeader(nurseSheet.getRange(1, 1, 1, headers.length), '#2C5F8A');
    nurseSheet.setFrozenRows(1);
    nurseSheet.getRange('B2:B100').setDataValidation(
      SpreadsheetApp.newDataValidation()
        .requireValueInList(['수간호사', 'P-D', 'P-E', '나이트전담', '일반', '신규'])
        .setAllowInvalid(false).build()
    );
    nurseSheet.getRange('C2:C100').setDataValidation(
      SpreadsheetApp.newDataValidation()
        .requireValueInList(['여', '남'])
        .setAllowInvalid(false).build()
    );
  }

  const nurses = loadNurses(ss);
  _refreshFixedSheet(ss, nurses, totalDays);

  const wantedSheet = getOrCreateSheet(ss, SHEET.WANTED);
  if (wantedSheet.getLastRow() === 0) {
    const headers = [
      '이름',
      '신청1_날짜', '신청1_유형',
      '신청2_날짜', '신청2_유형',
      '신청3_날짜', '신청3_유형',
      '신청4_날짜', '신청4_유형',
      '신청5_날짜', '신청5_유형',
    ];
    wantedSheet.appendRow(headers);
    styleHeader(wantedSheet.getRange(1, 1, 1, headers.length), '#2E8B57');
    wantedSheet.setFrozenRows(1);
    wantedSheet.getRange('A2').setValue('← 간호사 이름과 신청 날짜/유형을 입력하세요.');
    wantedSheet.getRange('A2').setFontColor('#888888').setFontStyle('italic');
  }

  ui.alert(
    `✅ ${year}년 ${month}월 준비 완료!\n\n` +
    `📌 공휴일 시트: 날짜/요일 갱신 완료\n` +
    `   → 공휴일 날짜에 체크해 주세요\n\n` +
    `📋 고정듀티: 날짜 열 재구성 완료\n` +
    `   → N전, 병, 헌, 돌봄, 분만, 건진 등 입력\n\n` +
    `📝 Wanted: 신청 내역 입력\n\n` +
    `🗂️ 전달근무표: 전달 결과표를 붙여넣기\n\n` +
    `준비 완료 후 [▶ 근무표 생성] 클릭`
  );
}

function _buildHolidaySheet(sh, yyyymm) {
  // 이전 달 데이터가 잔존하지 않도록 시트 전체 초기화
  sh.clearContents();
  sh.clearFormats();

  const year      = parseInt(yyyymm.slice(0, 4), 10);
  const month     = parseInt(yyyymm.slice(4, 6), 10);
  const totalDays = new Date(year, month, 0).getDate();
  const DOW_KR    = ['일', '월', '화', '수', '목', '금', '토'];

  sh.getRange('A1').setValue('대상 월').setFontWeight('bold').setFontColor('#888888');
  sh.getRange('B1').setValue(yyyymm).setBackground('#E8F0FE').setFontWeight('bold');

  sh.getRange('A3').setValue('날짜').setFontWeight('bold');
  sh.getRange('B3').setValue('요일').setFontWeight('bold');
  sh.getRange('C3').setValue('공휴일 체크').setFontWeight('bold');
  styleHeader(sh.getRange('A3:C3'), '#6A5ACD');

  for (let d = 1; d <= 31; d++) {
    const row = SETTINGS_DAY_START_ROW + d - 1;
    if (d <= totalDays) {
      const dow = new Date(year, month - 1, d).getDay();
      sh.getRange(row, 1).setValue(d);
      sh.getRange(row, 2).setValue(DOW_KR[dow]);
      sh.getRange(row, 3).insertCheckboxes();
      sh.getRange(row, 1, 1, 3).setBackground(null).setFontColor(null);
    } else {
      sh.getRange(row, 1).setValue(d);
      sh.getRange(row, 2).setValue('');
      sh.getRange(row, 1, 1, 3).setBackground('#EEEEEE').setFontColor('#AAAAAA');
    }
  }

  sh.setColumnWidth(1, 60);
  sh.setColumnWidth(2, 60);
  sh.setColumnWidth(3, 90);
}

function _refreshFixedSheet(ss, nurses, totalDays) {
  const sh = getOrCreateSheet(ss, SHEET.FIXED);

  const existingNames = [];
  if (sh.getLastRow() > 1) {
    const data = sh.getDataRange().getValues();
    for (let i = 1; i < data.length; i++) {
      const name = normalize(data[i][0]);
      if (name) existingNames.push(name);
    }
  }

  sh.clearContents();

  const header = ['이름'];
  for (let d = 1; d <= totalDays; d++) header.push(d);
  sh.appendRow(header);
  styleHeader(sh.getRange(1, 1, 1, header.length), '#6A5ACD');
  sh.setFrozenRows(1);
  sh.setFrozenColumns(1);

  const namesToFill = existingNames.length > 0
    ? existingNames
    : nurses.map(n => n.name);

  namesToFill.forEach(name => sh.appendRow([name]));

  sh.setColumnWidth(1, 100);
  for (let d = 2; d <= totalDays + 1; d++) sh.setColumnWidth(d, 36);
}

function menuGenerateBestOf() {
  const ui = SpreadsheetApp.getUi();
  const ss = SpreadsheetApp.getActiveSpreadsheet();

  let yyyymm;
  try { yyyymm = getTargetYYYYMM(ss); } catch(e) { ui.alert(e.message); return; }

  const year  = parseInt(yyyymm.slice(0, 4), 10);
  const month = parseInt(yyyymm.slice(4, 6), 10);

  try {
    ui.alert(`⏳ ${year}년 ${month}월 최적 근무표를 생성 중입니다...`);

    const result = runBestOf(ss, yyyymm);
    const { sched, nurses, holidays, prevHist, totalDays, finalViols, wantedMet, cleanCount, wanted } = result;

    const outSheet = writeOutput(ss, yyyymm, sched, nurses, holidays, year, month, totalDays, wanted);
    highlightViolations(outSheet, nurses, sched, totalDays, prevHist, year, month, holidays);

    const totalWanted = wanted.length;
    const unmetTotal  = wanted.filter(req => {
      const raw = sched[req.nurse.idx][req.day - 1] || '';
      return raw !== req.wtype && !(req.fallbackWtype && raw === req.fallbackWtype);
    }).length;

    const violMsg  = finalViols === 0 ? '✅ 위반 0건!' : `⚠️ 남은 위반: ${finalViols}건 (빨간 셀 확인)`;
    const cleanMsg = cleanCount > 0
      ? `🎯 위반 0건 후보 ${cleanCount}개 → 점수 기준 최적 선택`
      : `⚠️ 위반 0건 달성 실패 → 위반 최소 후보 중 점수 기준 선택`;

    ui.alert(`✅ ${year}년 ${month}월 근무표 생성 완료!`);

  } catch(e) {
    ui.alert('❌ 오류 발생:\n\n' + e.toString());
    Logger.log(e.stack);
  }
}

function menuPublish() {
  const ui = SpreadsheetApp.getUi();
  const ss = SpreadsheetApp.getActiveSpreadsheet();

  let yyyymm;
  try { yyyymm = getTargetYYYYMM(ss); } catch(e) { ui.alert(e.message); return; }

  const outSheetName = SHEET.OUTPUT_PREFIX + yyyymm;
  const outSheet     = ss.getSheetByName(outSheetName);
  if (!outSheet) {
    ui.alert(`❌ '${outSheetName}' 시트가 없습니다.\n먼저 [▶ 근무표 생성]을 실행해 주세요.`);
    return;
  }

  const year      = parseInt(yyyymm.slice(0, 4), 10);
  const month     = parseInt(yyyymm.slice(4, 6), 10);
  const totalDays = getTotalDays(yyyymm);

  try {
    const nurses   = loadNurses(ss);
    const holidays = loadHolidays(ss, year, month);
    const prevHist = loadPrevHistory(ss, yyyymm, nurses);
    loadPrevAccumData(ss, yyyymm, nurses);

    const sched = readScheduleFromSheet(outSheet, nurses, totalDays);

    const viols = countViolations(sched, nurses, prevHist, totalDays);

    {
      const totalRowsHL = outSheet.getLastRow();
      if (totalRowsHL > 1) {
        outSheet.getRange(2, 4, totalRowsHL - 1, totalDays)
          .setBackground(null).setFontColor('#000000').setFontWeight('normal');
      }
    }
    highlightViolations(outSheet, nurses, sched, totalDays, prevHist, year, month, holidays);

    if (viols > 0) {
      const forcePublish = ui.alert(
        `⚠️ 법적 위반 ${viols}건`,
        `빨간 셀에 법적 위반 ${viols}건이 있습니다.\n\n` +
        `위반 상태로 그냥 발행하시겠습니까?\n` +
        `(예: 위반 무시하고 발행 / 아니오: 취소하고 수정)`,
        ui.ButtonSet.YES_NO
      );
      if (forcePublish !== ui.Button.YES) return;  // YES = 그냥 발행, NO/닫기 = 취소
    } else {
      const confirm = ui.alert(
        '✅ 위반 없음 — 발행 확인',
        `${year}년 ${month}월 근무표를 발행합니다. 계속하시겠습니까?`,
        ui.ButtonSet.YES_NO
      );
      if (confirm !== ui.Button.YES) return;
    }

    const resultName = createResultSheet(ss, yyyymm, outSheet, nurses, totalDays);

    ui.alert(
      `✅ 발행 완료!\n\n` +
      `📋 ${resultName} 시트 생성 완료\n` +
      `   (출력표와 동일한 포맷 — 집계 포함)\n` +
      `📊 누적 오프·나이트 수: 결과표_${yyyymm} C열에 기록됨\n` +
      `   → 다음 달 전달근무표에 붙여넣으면 자동 반영`
    );

  } catch(e) {
    ui.alert('❌ 오류 발생:\n\n' + e.toString());
    Logger.log(e.stack);
  }
}
