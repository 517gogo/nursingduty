function _runOnce(nurses, fixedMap, wanted, prevHist, totalDays, year, month, holidays, locked) {
  nurses.forEach(n => { n.monthWanted = 0; });
  const sched = nurses.map(() => new Array(totalDays).fill(''));

  step1_Fixed(sched, nurses, fixedMap, totalDays);
  step2_AutoRoles(sched, nurses, totalDays, year, month, holidays);
  step3_Wanted(sched, nurses, wanted, totalDays, prevHist, year, month);
  step4_WeekendHolidayDuty(sched, nurses, totalDays, prevHist, year, month, holidays, locked);
  step5_NightDedicatedOff(sched, nurses, totalDays);
  step6_GeneralDuty(sched, nurses, totalDays, prevHist, year, month, holidays);
  enforceOffMax(sched, nurses, totalDays, prevHist, year, month, locked);
  step7_PreceptorMatch(sched, nurses, totalDays, prevHist, year, month, holidays, locked);

  return sched;
}

function countViolations(sched, nurses, prevHist, totalDays, year, month, holidays) {
  let count = 0;
  const targets = nurses.filter(n => !FIXED_AUTO_TYPES.has(n.type));

  targets.forEach(nurse => {
    let consec = 0;
    for (let d = 0; d < totalDays; d++) {
      const cur = sched[nurse.idx][d];

      if (!isAssigned(cur)) { consec = 0; continue; }

      if (d >= 1) {
        const prev1 = sched[nurse.idx][d - 1] || '';
        if (cur === DUTY.D && prev1 === DUTY.E)  count++;
        if (cur === DUTY.D && prev1 === DUTY.EDU_R) count++;  // 필교 뒤에 D 금지
        if (cur === DUTY.E && isNight(prev1))    count++;
        if (cur === DUTY.D && isNight(prev1))    count++;
        if (cur === DUTY.EDU_R && (prev1 === DUTY.E || isNight(prev1))) count++;
        // 9/10 전환 금지 규칙
        if ((cur === DUTY.D9 || cur === DUTY.D10) && isNight(prev1))           count++;
        if ((cur === DUTY.D9 || cur === DUTY.D10) && prev1 === DUTY.E)         count++;
        if (cur === DUTY.D && (prev1 === DUTY.D9 || prev1 === DUTY.D10))       count++;

        if (d >= 2) {
          const prev2 = sched[nurse.idx][d - 2] || '';
          if (cur === DUTY.D && (isOff(prev1) || isRecovery(prev1)) && isNight(prev2)) count++;
          // N-/-9 및 N-/-10 금지
          if ((cur === DUTY.D9 || cur === DUTY.D10) && (isOff(prev1) || isRecovery(prev1)) && isNight(prev2)) count++;
        }
      }

      if (isWork(cur)) {
        consec++;
        if (consec > RULES.MAX_CONSEC_WORK) count++;
      } else {
        consec = 0;
      }
    }
  });

  for (let d = 0; d < totalDays; d++) {
    const counts = countGeneralStaff(sched, nurses, d);
    [DUTY.D, DUTY.E, DUTY.N].forEach(s => {
      const n = counts[s] || 0;
      if (n < RULES.MIN_STAFF[s]) count++;
      if (n > RULES.MAX_STAFF[s]) count++;
    });
  }

  // D9/D10 인원 체크 (year/month/holidays 제공 시) — 일반 간호사만 대상
  if (year && month && holidays) {
    const allNurses = nurses.filter(n =>
      n.type === NURSE_TYPE.GENERAL
    );
    for (let d = 0; d < totalDays; d++) {
      const dow = new Date(year, month - 1, d + 1).getDay();
      const isHoliday_ = holidays instanceof Set && holidays.has(d + 1);

      if (dow === 6) {  // 토요일: 정확히 1명이 D9
        const cnt9 = allNurses.filter(n => sched[n.idx][d] === DUTY.D9).length;
        if (cnt9 !== 1) count++;
      }
      if (dow === 0 || isHoliday_) {  // 일요일/공휴일: 정확히 1명이 D10
        const cnt10 = allNurses.filter(n => sched[n.idx][d] === DUTY.D10).length;
        if (cnt10 !== 1) count++;
      }
    }
  }

  return count;
}

function countWantedMet(sched, wanted) {
  return wanted.filter(req => {
    const raw = sched[req.nurse.idx][req.day - 1] || '';
    return raw === req.wtype || (req.fallbackWtype && raw === req.fallbackWtype);
  }).length;
}

function scoreSchedule(sched, nurses, wanted, prevHist, totalDays) {
  let score = 0;

  wanted.forEach(req => {
    const raw = sched[req.nurse.idx][req.day - 1] || '';
    const met = raw === req.wtype || (req.fallbackWtype && raw === req.fallbackWtype);
    if (!met) score -= 10;
  });

  const targets = nurses.filter(n => !FIXED_AUTO_TYPES.has(n.type));
  targets.forEach(nurse => {
    for (let d = 0; d < totalDays; d++) {
      const cur = sched[nurse.idx][d] || '';

      const p1 = getSlot(sched, nurse.idx, d - 1, prevHist, totalDays);
      const p2 = getSlot(sched, nurse.idx, d - 2, prevHist, totalDays);
      const p3 = getSlot(sched, nurse.idx, d - 3, prevHist, totalDays);

      // DDDDD: D 5연속
      if (cur === DUTY.D) {
        let consecD = 1;
        for (let i = d - 1; i >= d - 4; i--) {
          if (getSlot(sched, nurse.idx, i, prevHist, totalDays) === DUTY.D) consecD++;
          else break;
        }
        if (consecD >= 5) score -= 5;

        // N//D: N → 오프 2개 → D
        if ((isOff(p1) || isRecovery(p1)) && (isOff(p2) || isRecovery(p2)) && isNight(p3)) score -= 5;

        // E/D: E → 오프 1개 → D
        if ((isOff(p1) || isRecovery(p1)) && p2 === DUTY.E) score -= 5;
      }

      // N/E: N → 오프 1개 → E
      if (cur === DUTY.E) {
        if ((isOff(p1) || isRecovery(p1)) && isNight(p2)) score -= 5;

        // /E/: 오프 → E → 오프
        if ((isOff(p1) || isRecovery(p1))) {
          const next1 = getSlot(sched, nurse.idx, d + 1, prevHist, totalDays);
          if (next1 && (isOff(next1) || isRecovery(next1))) score -= 5;
        }
      }

      // /D/: 오프 → D → 오프
      if (cur === DUTY.D) {
        if ((isOff(p1) || isRecovery(p1))) {
          const next1 = getSlot(sched, nurse.idx, d + 1, prevHist, totalDays);
          if (next1 && (isOff(next1) || isRecovery(next1))) score -= 5;
        }
      }

      // /N/: 오프 → N → 오프
      if (isNight(cur)) {
        if ((isOff(p1) || isRecovery(p1))) {
          const next1 = getSlot(sched, nurse.idx, d + 1, prevHist, totalDays);
          if (next1 && (isOff(next1) || isRecovery(next1))) score -= 5;
        }
      }
    }
  });

  return score;
}

function _variance(arr) {
  if (arr.length === 0) return 0;
  const mean = arr.reduce((a, b) => a + b, 0) / arr.length;
  return arr.reduce((sum, v) => sum + Math.pow(v - mean, 2), 0) / arr.length;
}


/**
 * ============================================================
 * step9_WantedRepair — Wanted 백트래킹 수리 (유연성 및 1:1 맞교환 추가)
 * ============================================================
 */
function step9_WantedRepair(sched, nurses, wanted, prevHist, totalDays, year, month, locked) {

  const snapSched = sched.map(r => [...r]);

  const reflectedMap = {};
  wanted.forEach(req => {
    const d   = req.day - 1;
    const cur = sched[req.nurse.idx][d] || '';
    if (cur === req.wtype || (req.fallbackWtype && cur === req.fallbackWtype)) {
      reflectedMap[`${req.nurse.idx}_${d}`] = req;
    }
  });

  const tieQueue = [];

  function tryAssignWanted(req) {
    const { nurse, day, wtype, fallbackWtype } = req;
    const d   = day - 1;
    const key = `${nurse.idx}_${d}`;

    const cur = sched[nurse.idx][d] || '';
    if (cur === wtype || (fallbackWtype && cur === fallbackWtype)) return true;

    const oldVal = sched[nurse.idx][d];

    // [핵심 보호] 사용자가 고정한 값은 절대 건드리지 않음
    if (locked[nurse.idx][d]) return false;
    if (isFixedDuty(oldVal)) return false; 

    // [개선 1] 전체 위반 0건이 아니라, "현재 위반 건수"를 기준으로 삼음
    const baseViols = countViolations(sched, nurses, prevHist, totalDays);

    // [개선 2] 1:1 근무 맞교환 (내가 D인데 E를 원할 때, E인 사람과 스왑)
    if (isWork(wtype) && isWork(oldVal)) {
      const swapCands = nurses.filter(m => {
        if (m.idx === nurse.idx) return false;
        if (FIXED_AUTO_TYPES.has(m.type) || m.type === NURSE_TYPE.NIGHT) return false;
        if (locked[m.idx][d] || isFixedDuty(sched[m.idx][d])) return false;
        return sched[m.idx][d] === wtype; // 내가 원하는 듀티를 가진 사람
      });

      for (const m of swapCands) {
        const mBackup = sched[m.idx][d];
        sched[m.idx][d] = oldVal; // 상대방이 내 듀티를 가져감
        sched[nurse.idx][d] = wtype; // 내가 상대방 듀티를 가져옴
        
        if (countViolations(sched, nurses, prevHist, totalDays) <= baseViols) {
          reflectedMap[key] = req;
          log(`[Step9] 1:1 맞교환 반영: ${nurse.name}(${oldVal}→${wtype}) ↔ ${m.name}`);
          return true;
        }
        // 실패 시 롤백
        sched[m.idx][d] = mBackup;
        sched[nurse.idx][d] = oldVal;
      }
    }

    let goto_B   = false;

    if (isWork(wtype)) {
      const dayCounts = countGeneralStaff(sched, nurses, d);
      const cntKey    = isNight(wtype) ? DUTY.N : wtype;
      if ((dayCounts[cntKey] || 0) >= RULES.MAX_STAFF[cntKey]) {
        goto_B = true;
      }
    }

    // 1. 단순 교체 (정원이 남거나, 오프를 원할 때 대타 구하기)
    if (!goto_B) {
      sched[nurse.idx][d] = wtype;
      let compensator = null;
      if (isOff(wtype) && isWork(oldVal)) {
        const shortage = oldVal;
        const dayCnts  = countGeneralStaff(sched, nurses, d);
        if ((dayCnts[shortage] || 0) < RULES.MIN_STAFF[shortage]) {
          for (const cand of nurses) {
            if (cand.idx === nurse.idx) continue;
            if (FIXED_AUTO_TYPES.has(cand.type) || cand.type === NURSE_TYPE.NIGHT) continue;

            const candCur = sched[cand.idx][d];
            if (candCur && candCur !== DUTY.OFF) continue;
            if (locked[cand.idx][d]) continue;

            const offCntC = sched[cand.idx].filter(v => isOff(v) && !isRecovery(v)).length;
            if (offCntC >= RULES.OFF_MAX) continue;
            const cnts2 = countGeneralStaff(sched, nurses, d);
            if ((cnts2[shortage] || 0) >= RULES.MAX_STAFF[shortage]) continue;
            if (!canAssignWork(sched, cand.idx, d, shortage, prevHist, totalDays, year, month)) continue;
            
            compensator = { nurse: cand, oldVal: candCur };
            sched[cand.idx][d] = shortage;
            break;
          }
        }
      }
      
      // [개선 1 적용] 전체 위반이 늘어나지 않으면 승인!
      if (countViolations(sched, nurses, prevHist, totalDays) <= baseViols) {
        reflectedMap[key] = req;
        log(`[Step9] 반영: ${nurse.name} ${day}일 → ${wtype}${compensator ? ` (대타: ${compensator.nurse.name} ${oldVal})` : ''}`);
        return true;
      }
      sched[nurse.idx][d] = oldVal;
      if (compensator) sched[compensator.nurse.idx][d] = compensator.oldVal;
      goto_B = isWork(wtype);
    }

    // 2. 밀어내기 (내가 원하는 근무 정원이 찼을 때 누군가를 오프로 밀어냄)
    if (isWork(wtype)) {
      const dayCounts2 = countGeneralStaff(sched, nurses, d);
      const countKey   = isNight(wtype) ? DUTY.N : wtype;
      if (goto_B || (dayCounts2[countKey] || 0) >= RULES.MAX_STAFF[countKey]) {
        const pushCandidates = nurses.filter(m => {
          if (m.idx === nurse.idx) return false;
          if (FIXED_AUTO_TYPES.has(m.type) || m.type === NURSE_TYPE.NIGHT) return false;
          if (locked[m.idx][d]) return false;

          const mDuty = sched[m.idx][d] || '';
          const mKey  = (mDuty === DUTY.N || mDuty === DUTY.N_FULL) ? DUTY.N : mDuty;
          return mKey === countKey;
        });

        for (const m of pushCandidates) {
          const mKey    = `${m.idx}_${d}`;
          const mBackup = sched[m.idx][d];
          const mWanted = reflectedMap[mKey];

          sched[m.idx][d]      = DUTY.OFF;
          sched[nurse.idx][d]  = wtype;

          if (countViolations(sched, nurses, prevHist, totalDays) <= baseViols) {
            if (mWanted) {
              const winner = resolveConflict([req, mWanted]);
              if (winner === null) {
                sched[m.idx][d]     = mBackup;
                sched[nurse.idx][d] = oldVal;
                tieQueue.push(req);
                return false;
              }
              if (winner.nurse.idx !== nurse.idx) {
                sched[m.idx][d]     = mBackup;
                sched[nurse.idx][d] = oldVal;
                return false;
              }
              sched[m.idx][d] = snapSched[m.idx][d];
              delete reflectedMap[mKey];
              if (countViolations(sched, nurses, prevHist, totalDays) <= baseViols) {
                reflectedMap[key] = req;
                log(`[Step9] 충돌 승리 반영: ${nurse.name} ${day}일 → ${wtype} (${m.name} 복원)`);
                return true;
              } else {
                sched[m.idx][d]     = mBackup;
                sched[nurse.idx][d] = oldVal;
                if (mWanted) reflectedMap[mKey] = mWanted;
                return false;
              }
            } else {
              reflectedMap[key] = req;
              log(`[Step9] 밀어내기 반영: ${nurse.name} ${day}일 → ${wtype} (${m.name} 오프)`);
              return true;
            }
          } else {
            sched[m.idx][d]     = mBackup;
            sched[nurse.idx][d] = oldVal;
          }
        }
      }
    }

    if (fallbackWtype) {
      sched[nurse.idx][d] = fallbackWtype;
      if (countViolations(sched, nurses, prevHist, totalDays) <= baseViols) {
        reflectedMap[key] = { ...req, wtype: fallbackWtype };
        log(`[Step9] fallback 반영: ${nurse.name} ${day}일 → ${fallbackWtype}`);
        return true;
      }
      sched[nurse.idx][d] = oldVal;
    }

    return false;
  }

  const MAX_PASSES = 3;

  function buildUnmetByNurse() {
    return nurses
      .filter(n => !FIXED_AUTO_TYPES.has(n.type))
      .map(nurse => {
        const unmet = wanted.filter(req => {
          if (req.nurse.idx !== nurse.idx) return false;
          const cur = sched[nurse.idx][req.day - 1] || '';
          return cur !== req.wtype && !(req.fallbackWtype && cur === req.fallbackWtype);
        });
        return { nurse, unmet };
      })
      .filter(x => x.unmet.length > 0)
      .sort((a, b) => {
        if (b.unmet.length !== a.unmet.length) return b.unmet.length - a.unmet.length;
        if (a.nurse.monthWanted !== b.nurse.monthWanted) return a.nurse.monthWanted - b.nurse.monthWanted;
        return b.nurse.accumOff - a.nurse.accumOff;
      });
  }

  for (let pass = 0; pass < MAX_PASSES; pass++) {
    const currentUnmet = buildUnmetByNurse();
    if (currentUnmet.length === 0) break;

    let anyProgress = false;
    for (const { unmet } of currentUnmet) {
      for (const req of unmet) {
        const result = tryAssignWanted(req);
        if (result) anyProgress = true;
      }
    }
    if (!anyProgress) break;
  }

  for (const req of tieQueue) {
    tryAssignWanted(req);
  }

}

function runBestOf(ss, yyyymm) {
  const year      = parseInt(yyyymm.slice(0, 4), 10);
  const month     = parseInt(yyyymm.slice(4, 6), 10);
  const totalDays = getTotalDays(yyyymm);

  const nurses   = loadNurses(ss);
  const holidays = loadHolidays(ss, year, month);
  const prevHist = loadPrevHistory(ss, yyyymm, nurses);
  loadPrevAccumData(ss, yyyymm, nurses);
  const fixedMap = loadFixedDuty(ss, yyyymm);
  const wanted   = loadWanted(ss, yyyymm, nurses);

  const locked = nurses.map(() => new Array(totalDays).fill(false));
  nurses.forEach(nurse => {
    const fixed = fixedMap[nurse.name];
    if (fixed) {
      for (let d = 1; d <= totalDays; d++) {
        if (fixed[d]) locked[nurse.idx][d - 1] = true;
      }
    }
    if (FIXED_AUTO_TYPES.has(nurse.type)) {
      for (let d = 0; d < totalDays; d++) {
        locked[nurse.idx][d] = true;
      }
    }
  });

  const generalIdxList = nurses
    .filter(n => n.type === NURSE_TYPE.GENERAL || n.type === NURSE_TYPE.NEW)
    .map(n => n.idx);

  const CANDIDATES = 20;
  const candidates = [];
  for (let t = 0; t < CANDIDATES; t++) {
    _shuffleNurseOrder(nurses, generalIdxList);
    const sched = _runOnce(nurses, fixedMap, wanted, prevHist, totalDays, year, month, holidays, locked);
    const viols = countViolations(sched, nurses, prevHist, totalDays, year, month, holidays);
    candidates.push({ sched: sched.map(r => [...r]), viols, tryNum: t + 1 });
    log(`[Phase1] 후보 ${t + 1}/${CANDIDATES}: 위반 ${viols}건`);
  }

  nurses.sort((a, b) => a.idx - b.idx);
  const repaired = candidates.map((cand, i) => {
    const sched = cand.sched.map(r => [...r]);
    step8_RepairViolations(sched, nurses, totalDays, prevHist, wanted, year, month, locked, holidays);
    const viols     = countViolations(sched, nurses, prevHist, totalDays, year, month, holidays);
    const wantedMet = countWantedMet(sched, wanted);
    log(`[Phase2] 후보 ${i + 1} 수리 후: 위반 ${viols}건, Wanted ${wantedMet}건`);
    return { sched, viols, wantedMet, tryNum: cand.tryNum };
  });

  const cleanOnes = repaired.filter(r => r.viols === 0);
  log(`[Phase3] 위반 0건 후보: ${cleanOnes.length}개`);

  const step9Pool = cleanOnes.length > 0 ? cleanOnes : (() => {
    const minViols = Math.min(...repaired.map(r => r.viols));
    return repaired.filter(r => r.viols === minViols);
  })();

  // [개선 3] 위반이 0건이 아니더라도 무조건 Wanted 수리(Step 9)를 시도하도록 수정
  const afterStep9 = step9Pool.map((cand, i) => {
    const sched = cand.sched.map(r => [...r]);
    const baseViols = cand.viols; // 수리 전 위반 건수 기억

    // 무조건 시도
    step9_WantedRepair(sched, nurses, wanted, prevHist, totalDays, year, month, locked);
    const newViols = countViolations(sched, nurses, prevHist, totalDays, year, month, holidays);
    
    // Wanted 반영하느라 오히려 위반이 늘어난 최악의 경우에만 롤백
    if (newViols > baseViols) {
      log(`[Phase3.5] 후보 ${cand.tryNum}: step9 후 위반 증가(${baseViols}→${newViols}) → 이전 상태 유지`);
      return { ...cand, sched: cand.sched.map(r => [...r]) };
    }
    
    const wantedMet = countWantedMet(sched, wanted);
    log(`[Phase3.5] 후보 ${cand.tryNum}: Wanted ${wantedMet}건 반영 (위반 ${newViols}건 유지)`);
    return { sched, viols: newViols, wantedMet, tryNum: cand.tryNum };
  });

  let chosen = afterStep9[0], bestScore = -Infinity;
  afterStep9.forEach(cand => {
    const sc = scoreSchedule(cand.sched, nurses, wanted, prevHist, totalDays);
    log(`[Phase4] 후보 ${cand.tryNum}: 점수 ${sc}, Wanted ${cand.wantedMet}건`);
    if (sc > bestScore) { bestScore = sc; chosen = cand; }
  });
  log(`[Phase4] 최종: 후보 ${chosen.tryNum} / 점수 ${bestScore} / 위반 ${chosen.viols}건`);

  // ============================================================
  // [Phase 5] ILS — Iterated Local Search
  //   현재 최선 후보를 반복적으로 교란(perturb) → 재건(rebuild) →
  //   수리(repair) 하여 로컬 최적에서 탈출하고 해를 개선한다.
  // ============================================================
  const ILS_ITER = 30;
  let ilsBest = {
    sched: chosen.sched.map(r => [...r]),
    score: bestScore,
    viols: chosen.viols,
  };

  for (let iter = 0; iter < ILS_ITER; iter++) {
    // 1. 교란: D/E/OFF 일부를 비워 새로운 탐색 공간 확보
    const perturbed = _perturbSched(ilsBest.sched, nurses, locked, totalDays);

    // 2. 재건: 빈 셀에 Wanted 우선 배정 후 일반 배정 로직으로 채움
    nurses.forEach(n => { n.monthWanted = 0; });
    step3_Wanted(perturbed, nurses, wanted, totalDays, prevHist, year, month);
    step6_GeneralDuty(perturbed, nurses, totalDays, prevHist, year, month, holidays);
    enforceOffMax(perturbed, nurses, totalDays, prevHist, year, month, locked);
    step7_PreceptorMatch(perturbed, nurses, totalDays, prevHist, year, month, holidays, locked);

    // 3. 위반 수리
    step8_RepairViolations(perturbed, nurses, totalDays, prevHist, wanted, year, month, locked, holidays);
    const viols = countViolations(perturbed, nurses, prevHist, totalDays, year, month, holidays);

    // 4. Wanted 반영 (위반이 악화되지 않는 경우에만)
    if (viols <= ilsBest.viols) {
      step9_WantedRepair(perturbed, nurses, wanted, prevHist, totalDays, year, month, locked);
    }

    const newViols = countViolations(perturbed, nurses, prevHist, totalDays, year, month, holidays);
    const newScore = scoreSchedule(perturbed, nurses, wanted, prevHist, totalDays);
    log(`[ILS] 반복 ${iter + 1}/${ILS_ITER}: 위반 ${newViols}건, 점수 ${newScore}`);

    // 5. 수용 기준: 위반 감소 OR (위반 동일 AND 점수 향상)
    if (newViols < ilsBest.viols || (newViols <= ilsBest.viols && newScore > ilsBest.score)) {
      ilsBest = { sched: perturbed.map(r => [...r]), score: newScore, viols: newViols };
      log(`[ILS] ✓ 개선: 위반 ${newViols}건, 점수 ${newScore}`);
    }
  }

  log(`[ILS] 완료 — 위반 ${ilsBest.viols}건, 점수 ${ilsBest.score} (초기 위반 ${chosen.viols}건, 점수 ${bestScore})`);

  return { sched: ilsBest.sched, nurses, holidays, prevHist, year, month, totalDays,
           finalViols: ilsBest.viols, wantedMet: countWantedMet(ilsBest.sched, wanted),
           cleanCount: cleanOnes.length, wanted };
}

function _shuffleNurseOrder(nurses, generalIdxList) {
  const positions = generalIdxList.map(idx => nurses.findIndex(n => n.idx === idx));
  for (let i = positions.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    const pi = positions[i], pj = positions[j];
    [nurses[pi], nurses[pj]] = [nurses[pj], nurses[pi]];
  }
}

/**
 * ILS 교란 함수: 현재 최선해의 일부 D/E/OFF 배정을 무작위로 초기화하여
 * 로컬 최적에서 탈출할 수 있도록 새로운 탐색 공간을 개척한다.
 * - K명의 일반/신규 간호사를 선택, 각각 N일의 배정을 비운다.
 * - 고정(locked), 야간, 특수휴가, 교육 셀은 건드리지 않는다.
 */
function _perturbSched(sched, nurses, locked, totalDays) {
  const K_NURSES = 4; // 교란할 간호사 수
  const N_DAYS   = 5; // 간호사당 초기화할 일수

  const copy = sched.map(r => [...r]);

  const pool = nurses.filter(n =>
    n.type === NURSE_TYPE.GENERAL || n.type === NURSE_TYPE.NEW
  );

  const shuffled = [...pool].sort(() => Math.random() - 0.5);
  const selected = shuffled.slice(0, Math.min(K_NURSES, shuffled.length));

  for (const nurse of selected) {
    const days = Array.from({ length: totalDays }, (_, i) => i)
      .sort(() => Math.random() - 0.5)
      .slice(0, N_DAYS);

    for (const d of days) {
      if (locked[nurse.idx][d]) continue;
      const cur = copy[nurse.idx][d];
      if (!cur) continue;
      // D, E, / 만 초기화 (야간·특수휴가·교육 등은 유지)
      if (cur !== DUTY.D && cur !== DUTY.E && cur !== DUTY.OFF) continue;
      copy[nurse.idx][d] = '';
    }
  }

  return copy;
}


function step1_Fixed(sched, nurses, fixedMap, totalDays) {
  nurses.forEach(nurse => {
    const fixed = fixedMap[nurse.name];
    if (!fixed) return;
    for (let d = 1; d <= totalDays; d++) {
      if (fixed[d]) sched[nurse.idx][d - 1] = fixed[d];
    }
  });
}


function step2_AutoRoles(sched, nurses, totalDays, year, month, holidays) {
  nurses.forEach(nurse => {
    if (!FIXED_AUTO_TYPES.has(nurse.type)) return;
    for (let d = 0; d < totalDays; d++) {
      if (sched[nurse.idx][d]) continue;
      const isOff_ = isWeekendOrHoliday(year, month, d + 1, holidays);
      if (nurse.type === NURSE_TYPE.HEAD)  sched[nurse.idx][d] = isOff_ ? DUTY.OFF : DUTY.HEAD_DUTY;
      if (nurse.type === NURSE_TYPE.P_D)   sched[nurse.idx][d] = isOff_ ? DUTY.OFF : DUTY.P_D_DUTY;
      if (nurse.type === NURSE_TYPE.P_E)   sched[nurse.idx][d] = isOff_ ? DUTY.OFF : DUTY.P_E_DUTY;
    }
  });
}



function step3_Wanted(sched, nurses, wantedReqs, totalDays, prevHist, year, month) {
  const processed = new Set();
  const tieQueue  = [];

  const orderedReqs = wantedReqs.map((req, i) => ({ req, i }));

  const groupMap = new Map();
  wantedReqs.forEach((req, i) => {
    const key = `${req.day}_${req.priority}`;
    if (!groupMap.has(key)) groupMap.set(key, []);
    groupMap.get(key).push({ req, i });
  });

  function processReq(req, i) {
    if (processed.has(i)) return;
    const { nurse, day, wtype } = req;
    const d = day - 1;

    if (isAssigned(sched[nurse.idx][d])) { processed.add(i); return; }
    if (wtype === DUTY.MENSES && sched[nurse.idx][d] === DUTY.N) { processed.add(i); return; }

    const transOk =
      checkTransition(sched, nurse.idx, d, wtype, prevHist, totalDays) &&
      checkForwardTransition(sched, nurse.idx, d, wtype, prevHist, totalDays);
    if (!transOk) {
      if (req.fallbackWtype) {
        const fbOk =
          checkTransition(sched, nurse.idx, d, req.fallbackWtype, prevHist, totalDays) &&
          checkForwardTransition(sched, nurse.idx, d, req.fallbackWtype, prevHist, totalDays);
        if (fbOk) sched[nurse.idx][d] = req.fallbackWtype;
      }
      processed.add(i);
      return;
    }

    if (isWork(wtype)) {
      const dayCount = countGeneralStaff(sched, nurses, d);
      if ((dayCount[wtype] || 0) >= RULES.MAX_STAFF[wtype]) {
        if (req.fallbackWtype) {
          const fbOk =
            checkTransition(sched, nurse.idx, d, req.fallbackWtype, prevHist, totalDays) &&
            checkForwardTransition(sched, nurse.idx, d, req.fallbackWtype, prevHist, totalDays);
          if (fbOk) sched[nurse.idx][d] = req.fallbackWtype;
        }
        processed.add(i);
        return;
      }
    }

    const key = `${day}_${req.priority}`;
    const group = groupMap.get(key) || [];
    const candidates = group
      .filter(({ req: r, i: idx }) => !processed.has(idx) && !isAssigned(sched[r.nurse.idx][r.day - 1]))
      .map(({ req: r, i: idx }) => ({ req: r, i: idx }));

    if (candidates.length <= 1) {
      sched[nurse.idx][d] = wtype;
      processed.add(i);
    } else {
      const winner = resolveConflict(candidates.map(c => c.req));
      if (winner === null) {
        candidates.forEach(({ req: r, i: idx }) => { processed.add(idx); tieQueue.push(r); });
      } else {
        sched[winner.nurse.idx][winner.day - 1] = winner.wtype;
        candidates.forEach(({ i: idx }) => processed.add(idx));
      }
    }
  }

  orderedReqs.forEach(({ req, i }) => processReq(req, i));

  tieQueue.forEach(req => {
    const d = req.day - 1;
    if (!isAssigned(sched[req.nurse.idx][d])) {
      if (isWork(req.wtype)) {
        const dayCounts = countGeneralStaff(sched, nurses, d);
        if ((dayCounts[req.wtype] || 0) >= RULES.MAX_STAFF[req.wtype]) return;
      }
      const ok =
        checkTransition(sched, req.nurse.idx, d, req.wtype, prevHist, totalDays) &&
        checkForwardTransition(sched, req.nurse.idx, d, req.wtype, prevHist, totalDays);
      if (ok) sched[req.nurse.idx][d] = req.wtype;
    }
  });
}

function resolveConflict(candidates) {
  const minW = Math.min(...candidates.map(c => c.nurse.monthWanted));
  let pool = candidates.filter(c => c.nurse.monthWanted === minW);
  if (pool.length === 1) return pool[0];
  const maxA = Math.max(...pool.map(c => c.nurse.accumOff));
  pool = pool.filter(c => c.nurse.accumOff === maxA);
  if (pool.length === 1) return pool[0];
  return null;
}


/**
 * step4_WeekendHolidayDuty:
 *   - 토요일(dow=6) → 일반 간호사 중 1명에게 DUTY.D9 배정
 *   - 일요일(dow=0) 또는 공휴일 → 일반 간호사 중 1명에게 DUTY.D10 배정
 *   - 이미 배정된 셀, 고정(locked) 셀, 전환 규칙 위반 대상은 건너뜀
 */
function step4_WeekendHolidayDuty(sched, nurses, totalDays, prevHist, year, month, holidays, locked) {
  const pool = nurses.filter(n =>
    n.type === NURSE_TYPE.GENERAL
  );

  for (let d = 0; d < totalDays; d++) {
    const dow = new Date(year, month - 1, d + 1).getDay();
    const isHoliday_ = holidays instanceof Set && holidays.has(d + 1);

    let targetDuty = null;
    if (dow === 6) targetDuty = DUTY.D9;               // 토요일
    else if (dow === 0 || isHoliday_) targetDuty = DUTY.D10; // 일요일 또는 공휴일

    if (!targetDuty) continue;

    // 이미 배정된 경우 건너뜀
    if (pool.some(n => sched[n.idx][d] === targetDuty)) continue;

    // 무작위 순서로 적격 간호사 탐색
    const shuffled = [...pool].sort(() => Math.random() - 0.5);
    for (const nurse of shuffled) {
      if (isAssigned(sched[nurse.idx][d])) continue;
      if (locked[nurse.idx][d]) continue;
      if (!canAssignWork(sched, nurse.idx, d, targetDuty, prevHist, totalDays, year, month)) continue;
      sched[nurse.idx][d] = targetDuty;
      log(`[Step4] ${nurse.name} ${d + 1}일 → ${targetDuty}`);
      break;
    }
  }
}


function step5_NightDedicatedOff(sched, nurses, totalDays) {
  nurses.filter(n => n.type === NURSE_TYPE.NIGHT).forEach(nurse => {
    for (let d = 0; d < totalDays; d++) {
      if (!isAssigned(sched[nurse.idx][d])) sched[nurse.idx][d] = DUTY.OFF;
    }
  });
}



function step6_GeneralDuty(sched, nurses, totalDays, prevHist, year, month, holidays) {
  const targetNurses = nurses.filter(n =>
    n.type === NURSE_TYPE.GENERAL || n.type === NURSE_TYPE.NEW
  );


  function getNurseCounts(nurse) {
    let d_ = 0, e_ = 0, n_ = 0, off_ = 0, special_ = 0;
    for (let d = 0; d < totalDays; d++) {
      const v = sched[nurse.idx][d];
      if (v === DUTY.D) d_++;
      else if (v === DUTY.E) e_++;
      else if (isNight(v)) n_++;
      else if (isOff(v) && !isRecovery(v)) off_++;
      else if (v === DUTY.D9 || v === DUTY.D10) special_++;  // D 인원 카운트와 무관하게 근무일 산정
    }
    return { D: d_, E: e_, N: n_, off: off_, special: special_ };
  }

  function remainingEmpty(nurse, fromDay) {
    let cnt = 0;
    for (let d = fromDay; d < totalDays; d++) {
      if (!isAssigned(sched[nurse.idx][d])) cnt++;
    }
    return cnt;
  }

  let baseOff = 0;
  for (let d = 1; d <= totalDays; d++) {
    if (isWeekendOrHoliday(year, month, d, holidays)) baseOff++;
  }
  const targetOff = Math.min(RULES.OFF_MAX, Math.max(RULES.OFF_MIN, baseOff));

  function getTargets(nurse) {
    const fixed = getNurseCounts(nurse);
    const totalWork  = totalDays - targetOff;
    const remainWork = Math.max(0, totalWork - fixed.D - fixed.E - fixed.N - fixed.special);  // 9/10도 근무일 차감
    const remainOff  = Math.max(0, targetOff - fixed.off);
    const each = Math.floor(remainWork / 2);
    return { D: each, E: remainWork - each, off: remainOff };
  }

  for (let d = 0; d < totalDays; d++) {
    const counts = countGeneralStaff(sched, nurses, d);

    const shuffled = [...targetNurses].sort((a, b) => {
      const ca = getNurseCounts(a), cb = getNurseCounts(b);
      const offLeftA = (targetOff - ca.off) - remainingEmpty(a, d);
      const offLeftB = (targetOff - cb.off) - remainingEmpty(b, d);
      return offLeftA - offLeftB;
    });

    // [팀 커버리지 패스] 각 팀에 D, E 최소 1명 배정 보장
    const teams = getTeams(nurses);
    for (const team of teams) {
      for (const duty of [DUTY.D, DUTY.E]) {
        const tc = countTeamStaff(sched, nurses, team, d);
        if (tc[duty] > 0) continue; // 이미 커버됨

        const teamNurses = shuffled.filter(n => n.team === team);
        for (const nurse of teamNurses) {
          if (isAssigned(sched[nurse.idx][d])) continue;
          if ((counts[duty] || 0) >= RULES.MAX_STAFF[duty]) break;
          if (!canAssignWork(sched, nurse.idx, d, duty, prevHist, totalDays, year, month)) continue;
          sched[nurse.idx][d] = duty;
          counts[duty]++;
          break;
        }
      }
    }

    for (const nurse of shuffled) {
      if (isAssigned(sched[nurse.idx][d])) continue;

      const nc      = getNurseCounts(nurse);
      const targets = getTargets(nurse);

      const shortage = [DUTY.D, DUTY.E].filter(s =>
        (counts[s] || 0) < RULES.MIN_STAFF[s] &&
        (counts[s] || 0) < RULES.MAX_STAFF[s]
      );
      if (shortage.length === 0) continue;

      const options = shortage.filter(duty =>
        canAssignWork(sched, nurse.idx, d, duty, prevHist, totalDays, year, month)
      );
      if (options.length === 0) continue;

      options.sort((a, b) => {
        const needA = Math.max(0, RULES.MIN_STAFF[a] - (counts[a] || 0));
        const needB = Math.max(0, RULES.MIN_STAFF[b] - (counts[b] || 0));
        if (needB !== needA) return needB - needA;
        return (targets[b] - nc[b]) - (targets[a] - nc[a]);
      });

      sched[nurse.idx][d] = options[0];
      counts[options[0]]++;
    }

    for (const nurse of shuffled) {
      if (isAssigned(sched[nurse.idx][d])) continue;

      const nc      = getNurseCounts(nurse);
      const targets = getTargets(nurse);
      const remDays = remainingEmpty(nurse, d + 1);

      const offNeeded = Math.max(0, targetOff - nc.off);
      const mustOff   = offNeeded > 0 && offNeeded >= remDays + 1;
      const offFull   = nc.off >= RULES.OFF_MAX;

      if (mustOff && canAssignOff(sched, nurse.idx, d, DUTY.OFF, prevHist, totalDays)) {
        sched[nurse.idx][d] = DUTY.OFF;
        continue;
      }

      const dutyPool   = [DUTY.D, DUTY.E];
      const workOptions = dutyPool.filter(duty =>
        (counts[duty] || 0) < RULES.MAX_STAFF[duty] &&
        canAssignWork(sched, nurse.idx, d, duty, prevHist, totalDays, year, month)
      );

      const canOff_ = !offFull && canAssignOff(sched, nurse.idx, d, DUTY.OFF, prevHist, totalDays);

      if (workOptions.length === 0) {
        sched[nurse.idx][d] = DUTY.OFF;
        continue;
      }

      const allMet = [DUTY.D, DUTY.E].every(s => (counts[s] || 0) >= RULES.MIN_STAFF[s]);
      if (allMet && canOff_ && nc.off < targetOff) {
        sched[nurse.idx][d] = DUTY.OFF;
        continue;
      }

      workOptions.sort((a, b) => {
        const tgtA = targets[a] - nc[a], tgtB = targets[b] - nc[b];
        if (tgtB !== tgtA) return tgtB - tgtA;
        return Math.max(0, RULES.MIN_STAFF[b] - (counts[b] || 0)) -
               Math.max(0, RULES.MIN_STAFF[a] - (counts[a] || 0));
      });

      const chosen = workOptions[0];
      sched[nurse.idx][d] = chosen;
      if (counts[chosen] !== undefined) counts[chosen]++;
    }
  }
}

function enforceOffMax(sched, nurses, totalDays, prevHist, year, month, locked) {
  const targets = nurses.filter(n =>
    n.type === NURSE_TYPE.GENERAL || n.type === NURSE_TYPE.NEW
  );

  targets.forEach(nurse => {
    const plainOffCount = () =>
      sched[nurse.idx].filter(v => isOff(v) && !isRecovery(v)).length;

    if (plainOffCount() <= RULES.OFF_MAX) return;

    for (let d = 0; d < totalDays && plainOffCount() > RULES.OFF_MAX; d++) {
      if (sched[nurse.idx][d] !== DUTY.OFF) continue; 
      // [핵심 보호] 사용자가 고정한 순수 오프(/)는 빼앗지 않는다.
      if (locked[nurse.idx][d]) continue;

      const counts = countGeneralStaff(sched, nurses, d);
      const workOk = [DUTY.D, DUTY.E].find(duty =>
        (counts[duty] || 0) < RULES.MAX_STAFF[duty] &&
        canAssignWork(sched, nurse.idx, d, duty, prevHist, totalDays, year, month)
      );
      if (!workOk) continue;

      sched[nurse.idx][d] = workOk;
      log(`[OffMax] ${nurse.name} ${d+1}일 오프→${workOk} (OFF_MAX 초과 교정)`);
    }

    if (plainOffCount() > RULES.OFF_MAX) {
      log(`[OffMax] ⚠️ ${nurse.name} 오프 ${plainOffCount()}개 — OFF_MAX(${RULES.OFF_MAX}) 초과 유지 (N전환규칙 등으로 교정 불가)`);
    }
  });
}

function step7_PreceptorMatch(sched, nurses, totalDays, prevHist, year, month, holidays, locked) {
  // 신규 간호사를 일반 간호사와 동일하게 배정하므로 프리셉터 동기화 처리 없음
}


function step8_RepairViolations(sched, nurses, totalDays, prevHist, wanted, year, month, locked, holidays) {

  const wantedSet = new Set();
  if (wanted) {
    wanted.forEach(req => {
      const cur = sched[req.nurse.idx][req.day - 1] || '';
      if (cur === req.wtype || (req.fallbackWtype && cur === req.fallbackWtype)) {
        wantedSet.add(`${req.nurse.idx}_${req.day - 1}`);
      }
    });
  }
  const isWantedCell = (nurseIdx, d) => wantedSet.has(`${nurseIdx}_${d}`);

  const repairTargets = nurses.filter(n => !FIXED_AUTO_TYPES.has(n.type));

  function isCellFixed(nurseIdx, d, duty) {
    if (d >= 0 && d < totalDays && locked[nurseIdx][d]) return true; 
    if (d < 0) return true; 
    
    if (isNight(duty) || duty === DUTY.N_FULL) return true;
    if (isOff(duty) && duty !== DUTY.OFF) return true; 
    if (isRecovery(duty)) return true;
    if (duty === DUTY.EDU || duty === DUTY.EDU_R) return true;
    return false;
  }

  function collectViolations() {
    const viols = [];

    repairTargets.forEach(nurse => {
      for (let d = 0; d < totalDays; d++) {
        const curRaw = sched[nurse.idx][d];
        if (!isAssigned(curRaw)) continue;
        const cur   = curRaw;
        const prev1 = getSlot(sched, nurse.idx, d - 1, prevHist, totalDays);
        const prev2 = getSlot(sched, nurse.idx, d - 2, prevHist, totalDays);

        if (cur === DUTY.D && prev1 === DUTY.E)                                       viols.push({ nurse, d, type: 'E→D' });
        if (cur === DUTY.E && isNight(prev1))                                         viols.push({ nurse, d, type: 'N→E' });
        if (cur === DUTY.D && isNight(prev1))                                         viols.push({ nurse, d, type: 'N→D' });
        if (cur === DUTY.D && (isOff(prev1) || isRecovery(prev1)) && isNight(prev2)) viols.push({ nurse, d, type: 'N→/→D' });
        if (cur === DUTY.EDU_R && prev1 === DUTY.E)                                   viols.push({ nurse, d, type: 'E→필교' });
        if (cur === DUTY.EDU_R && isNight(prev1))                                     viols.push({ nurse, d, type: 'N→필교' });
        // 9/10 전환 금지 규칙
        if ((cur === DUTY.D9 || cur === DUTY.D10) && isNight(prev1))                  viols.push({ nurse, d, type: `N→${cur}` });
        if ((cur === DUTY.D9 || cur === DUTY.D10) && prev1 === DUTY.E)                viols.push({ nurse, d, type: `E→${cur}` });
        if ((cur === DUTY.D9 || cur === DUTY.D10) && (isOff(prev1) || isRecovery(prev1)) && isNight(prev2)) viols.push({ nurse, d, type: `N→/→${cur}` });
        if (cur === DUTY.D && (prev1 === DUTY.D9 || prev1 === DUTY.D10))              viols.push({ nurse, d, type: '9/10→D' });

        if (isWork(cur)) {
          let consec = 1;
          for (let i = d - 1; i >= 0; i--) {
            if (isWork(getSlot(sched, nurse.idx, i, prevHist, totalDays))) consec++;
            else break;
          }
          if (consec > RULES.MAX_CONSEC_WORK) viols.push({ nurse, d, type: 'CONSEC' });
        }
      }
    });

    for (let d = 0; d < totalDays; d++) {
      const counts = countGeneralStaff(sched, nurses, d);
      [DUTY.D, DUTY.E, DUTY.N].forEach(s => {
        const n = counts[s] || 0;
        if (n < RULES.MIN_STAFF[s]) viols.push({ nurse: null, d, type: `UNDER_${s}`, duty: s, count: n });
        if (n > RULES.MAX_STAFF[s]) viols.push({ nurse: null, d, type: `OVER_${s}`,  duty: s, count: n });
      });
      // 팀별 D/E 최소 배정 위반 감지
      const teams_ = getTeams(nurses);
      for (const team of teams_) {
        const tc = countTeamStaff(sched, nurses, team, d);
        if (tc.D === 0) viols.push({ nurse: null, d, type: `TEAM_UNDER_D_${team}`, duty: DUTY.D, team });
        if (tc.E === 0) viols.push({ nurse: null, d, type: `TEAM_UNDER_E_${team}`, duty: DUTY.E, team });
      }
    }

    // D9/D10 인원 위반 감지 (holidays 제공 시) — 일반 간호사만 대상
    if (holidays) {
      const allTargets = nurses.filter(n =>
        n.type === NURSE_TYPE.GENERAL
      );
      for (let d = 0; d < totalDays; d++) {
        const dow = new Date(year, month - 1, d + 1).getDay();
        const isHoliday_ = holidays instanceof Set && holidays.has(d + 1);
        if (dow === 6) {
          const cnt9 = allTargets.filter(n => sched[n.idx][d] === DUTY.D9).length;
          if (cnt9 < 1) viols.push({ nurse: null, d, type: 'UNDER_9',  duty: DUTY.D9 });
          if (cnt9 > 1) viols.push({ nurse: null, d, type: 'OVER_9',   duty: DUTY.D9 });
        }
        if (dow === 0 || isHoliday_) {
          const cnt10 = allTargets.filter(n => sched[n.idx][d] === DUTY.D10).length;
          if (cnt10 < 1) viols.push({ nurse: null, d, type: 'UNDER_10', duty: DUTY.D10 });
          if (cnt10 > 1) viols.push({ nurse: null, d, type: 'OVER_10',  duty: DUTY.D10 });
        }
      }
    }

    return viols;
  }

  function compensate(day, duty) {
    const dayCounts = countGeneralStaff(sched, nurses, day);
    if ((dayCounts[duty] || 0) >= RULES.MAX_STAFF[duty]) return false;
    for (const nurse of repairTargets) {
      const cur = sched[nurse.idx][day];
      if (cur && cur !== DUTY.OFF) continue;
      
      if (locked[nurse.idx][day]) continue; 
      
      if (!canAssignWork(sched, nurse.idx, day, duty, prevHist, totalDays, year, month)) continue;
      
      const offCount = sched[nurse.idx].filter(v => isOff(v) && !isRecovery(v)).length;
      if (offCount >= RULES.OFF_MAX) continue;

      const updatedCounts = countGeneralStaff(sched, nurses, day);
      if ((updatedCounts[duty] || 0) >= RULES.MAX_STAFF[duty]) return false;
      sched[nurse.idx][day] = duty;
      return true;
    }
    return false;
  }

  function compensateTeam(day, duty, team) {
    const dayCounts = countGeneralStaff(sched, nurses, day);
    if ((dayCounts[duty] || 0) >= RULES.MAX_STAFF[duty]) return false;
    const teamNurses = repairTargets.filter(n =>
      n.team === team && (n.type === NURSE_TYPE.GENERAL || n.type === NURSE_TYPE.NEW)
    );
    for (const nurse of teamNurses) {
      const cur = sched[nurse.idx][day];
      if (cur && cur !== DUTY.OFF) continue;
      if (locked[nurse.idx][day]) continue;
      if (!canAssignWork(sched, nurse.idx, day, duty, prevHist, totalDays, year, month)) continue;
      const offCount = sched[nurse.idx].filter(v => isOff(v) && !isRecovery(v)).length;
      if (offCount >= RULES.OFF_MAX) continue;
      sched[nurse.idx][day] = duty;
      return true;
    }
    return false;
  }

  function getCandidates(viol) {
    const { nurse, d, type } = viol;
    const prev1 = getSlot(sched, nurse.idx, d - 1, prevHist, totalDays);
    const cands = [];

    if (type === 'E→D') {
      if (!isCellFixed(nurse.idx, d - 1, prev1)) cands.push({ nurse, d: d - 1, was: prev1 });
      if (!isCellFixed(nurse.idx, d, sched[nurse.idx][d])) cands.push({ nurse, d, was: sched[nurse.idx][d] });
    } else if (type === 'N→E' || type === 'N→D') {
      if (!isCellFixed(nurse.idx, d, sched[nurse.idx][d])) cands.push({ nurse, d, was: sched[nurse.idx][d] });
    } else if (type === 'N→/→D') {
      if (!isCellFixed(nurse.idx, d, sched[nurse.idx][d])) cands.push({ nurse, d, was: sched[nurse.idx][d] });
      if (!isCellFixed(nurse.idx, d - 1, prev1)) cands.push({ nurse, d: d - 1, was: prev1 });
    } else if (type === 'E→필교' || type === 'N→필교') {
      if (!isCellFixed(nurse.idx, d - 1, prev1)) cands.push({ nurse, d: d - 1, was: prev1 });
      if (!isCellFixed(nurse.idx, d, sched[nurse.idx][d])) cands.push({ nurse, d, was: sched[nurse.idx][d] });
    } else if (type.startsWith('N→') && (type.endsWith('9') || type.endsWith('10'))) {
      // N→9, N→10: 해당 9/10 셀을 교체 대상으로
      if (!isCellFixed(nurse.idx, d, sched[nurse.idx][d])) cands.push({ nurse, d, was: sched[nurse.idx][d] });
    } else if (type.startsWith('E→') && (type.endsWith('9') || type.endsWith('10'))) {
      // E→9, E→10: 전일 E 또는 해당 9/10 셀 교체
      if (!isCellFixed(nurse.idx, d - 1, prev1)) cands.push({ nurse, d: d - 1, was: prev1 });
      if (!isCellFixed(nurse.idx, d, sched[nurse.idx][d])) cands.push({ nurse, d, was: sched[nurse.idx][d] });
    } else if (type.startsWith('N→/→') && (type.endsWith('9') || type.endsWith('10'))) {
      // N→/→9, N→/→10: 해당 9/10 셀 또는 중간 오프 셀 교체
      if (!isCellFixed(nurse.idx, d, sched[nurse.idx][d])) cands.push({ nurse, d, was: sched[nurse.idx][d] });
      if (!isCellFixed(nurse.idx, d - 1, prev1)) cands.push({ nurse, d: d - 1, was: prev1 });
    } else if (type === '9/10→D') {
      // 9/10 다음날 D: 해당 D 셀을 교체
      if (!isCellFixed(nurse.idx, d, sched[nurse.idx][d])) cands.push({ nurse, d, was: sched[nurse.idx][d] });
    } else if (type === 'CONSEC') {
      let start = d;
      while (start > 0 && isWork(getSlot(sched, nurse.idx, start - 1, prevHist, totalDays))) start--;
      const mid = Math.floor((start + d) / 2);
      for (let offset = 0; offset <= d - start; offset++) {
        const fw = mid + offset, bw = mid - offset;
        if (fw <= d && !isCellFixed(nurse.idx, fw, sched[nurse.idx][fw])) cands.push({ nurse, d: fw, was: sched[nurse.idx][fw] });
        if (bw >= start && bw !== fw && !isCellFixed(nurse.idx, bw, sched[nurse.idx][bw])) cands.push({ nurse, d: bw, was: sched[nurse.idx][bw] });
      }
    }
    cands.sort((a, b) => {
      const aW = isWantedCell(a.nurse.idx, a.d) ? 1 : 0;
      const bW = isWantedCell(b.nurse.idx, b.d) ? 1 : 0;
      return aW - bW;
    });
    return cands;
  }

  const MAX_ITER = 150;
  let iter = 0, totalFixed = 0;

  while (iter < MAX_ITER) {
    iter++;
    const viols = collectViolations();
    if (viols.length === 0) break;

    const viol = viols[0];

    if (viol.type && viol.type.startsWith('OVER_')) {
      const { d, duty } = viol;
      const overCands = repairTargets
        .filter(n => sched[n.idx][d] === duty && !isCellFixed(n.idx, d, sched[n.idx][d]))
        .sort((a, b) => {
          const aW = isWantedCell(a.idx, d) ? 1 : 0;
          const bW = isWantedCell(b.idx, d) ? 1 : 0;
          return aW - bW; 
        });
      let removed = false;
      for (const nurse of overCands) {
        const offCnt = sched[nurse.idx].filter(v => isOff(v) && !isRecovery(v)).length;
        if (offCnt >= RULES.OFF_MAX) continue;
        sched[nurse.idx][d] = DUTY.OFF;
        totalFixed++;
        removed = true;
        if (isWantedCell(nurse.idx, d)) log(`[Repair-OVER] Wanted 셀 부득이 제거: ${nurse.name} ${d+1}일 ${duty}`);
        break;
      }
      if (!removed) iter = MAX_ITER;
      continue;
    }

    if (viol.type && viol.type.startsWith('UNDER_')) {
      const { d, duty } = viol;
      if (!compensate(d, duty)) iter = MAX_ITER;
      else totalFixed++;
      continue;
    }

    if (viol.type && viol.type.startsWith('TEAM_UNDER_')) {
      const { d, duty, team } = viol;
      if (!compensateTeam(d, duty, team)) iter = MAX_ITER;
      else totalFixed++;
      continue;
    }

    const cands = getCandidates(viol);
    let fixed = false;
    for (const cand of cands) {
      const { nurse, d, was } = cand;
      const offCntCand = sched[nurse.idx].filter(v => isOff(v) && !isRecovery(v)).length;
      if (offCntCand >= RULES.OFF_MAX) continue;
      sched[nurse.idx][d] = DUTY.OFF;
      let sideEffect = false;
      if (isWork(was)) {
        const counts = countGeneralStaff(sched, nurses, d);
        [DUTY.D, DUTY.E, DUTY.N].forEach(s => {
          if ((counts[s] || 0) < RULES.MIN_STAFF[s]) {
            if (!compensate(d, s)) sideEffect = true;
          }
        });
      }
      const newViols = collectViolations();
      if (newViols.length >= viols.length && sideEffect) {
        sched[nurse.idx][d] = was;
        continue;
      }
      totalFixed++;
      fixed = true;
      break;
    }

    if (!fixed) {
      const { nurse, d } = viol;
      if (nurse && !isCellFixed(nurse.idx, d, sched[nurse.idx][d]) && !isWantedCell(nurse.idx, d)) {
        const offCntLast = sched[nurse.idx].filter(v => isOff(v) && !isRecovery(v)).length;
        if (offCntLast < RULES.OFF_MAX) {
          sched[nurse.idx][d] = DUTY.OFF;
          totalFixed++;
        }
      } else if (nurse && !isCellFixed(nurse.idx, d, sched[nurse.idx][d]) && isWantedCell(nurse.idx, d)) {
        const offCntLast = sched[nurse.idx].filter(v => isOff(v) && !isRecovery(v)).length;
        if (offCntLast < RULES.OFF_MAX) {
          log(`[Repair-Last] Wanted 셀 강제 제거: ${nurse.name} ${d+1}일`);
          sched[nurse.idx][d] = DUTY.OFF;
          totalFixed++;
        }
      } else {
        break;
      }
    }
  }

  if (totalFixed > 0) log(`[Repair] ${iter}회 반복, ${totalFixed}개 셀 수정`);
  if (iter >= MAX_ITER) log(`[Repair] 최대 반복 도달 — 남은 위반은 수동 조정 필요`);
}


/**
 * ============================================================
 * Output.gs — 근무표 출력 및 발행
 * ============================================================
 */

function writeOutput(ss, yyyymm, sched, nurses, holidays, year, month, totalDays, wanted) {
  const sheetName = SHEET.OUTPUT_PREFIX + yyyymm;
  const out       = recreateSheet(ss, sheetName);

  const DOW_LABELS = ['일', '월', '화', '수', '목', '금', '토'];
  const DATE_COL   = 4;                         
  const STAT_START = DATE_COL + totalDays;      

  const header = ['성명', '전달\n잔여', '이번달\n잔여'];
  for (let d = 1; d <= totalDays; d++) {
    const dow = getDayOfWeek(year, month, d);
    header.push(`${d}\n${DOW_LABELS[dow]}`);
  }
  header.push('D', 'E', 'N', '/', '미반영\nWanted', 'Wanted\n신청내역');
  out.appendRow(header);

  let lastTeam = '';
  const nurseRows = [];

  nurses.forEach(nurse => {
    if (nurse.team && nurse.team !== lastTeam && !FIXED_AUTO_TYPES.has(nurse.type)) {
      out.appendRow([`${nurse.team}팀`, ...new Array(totalDays + 7).fill('')]);
      lastTeam = nurse.team;
    }

    const curRow = out.getLastRow() + 1;
    const row = [nurse.name, nurse.accumOff, ''];
    for (let d = 0; d < totalDays; d++) {
      row.push(sched[nurse.idx][d] || '');
    }

    const nurseWanted   = (wanted || []).filter(req => req.nurse.idx === nurse.idx);
    const unmetCount    = nurseWanted.filter(req => {
      const raw = sched[nurse.idx][req.day - 1] || '';
      return raw !== req.wtype && !(req.fallbackWtype && raw === req.fallbackWtype);
    }).length;
    const unmetDisplay  = nurseWanted.length > 0 ? unmetCount : '';
    const wantedSummary = nurseWanted.length > 0
      ? nurseWanted.map(r => r.fallbackWtype ? `${r.day}(${r.wtype} or ${r.fallbackWtype})` : `${r.day}(${r.wtype})`).join(', ') : '';

    row.push('', '', '', '', unmetDisplay, wantedSummary);
    out.appendRow(row);
    nurseRows.push({ sheetRow: out.getLastRow(), nurse, isFixed: FIXED_AUTO_TYPES.has(nurse.type) });
  });

  _appendDailyCountRowFormula(out, nurses, totalDays, nurseRows);

  const dayStartCol = colToLetter(DATE_COL);
  const dayEndCol   = colToLetter(DATE_COL + totalDays - 1);
  const statD = colToLetter(STAT_START);
  const statE = colToLetter(STAT_START + 1);
  const statN = colToLetter(STAT_START + 2);
  const statO = colToLetter(STAT_START + 3);

  let baseOff = 0;
  for (let d = 1; d <= totalDays; d++) {
    if (isWeekendOrHoliday(year, month, d, holidays)) baseOff++;
  }

  nurseRows.forEach(({ sheetRow, nurse, isFixed }) => {
    const r = sheetRow;
    const rangeRef = `${dayStartCol}${r}:${dayEndCol}${r}`;

    out.getRange(r, STAT_START    ).setFormula(`=COUNTIF(${rangeRef},"D")`);
    out.getRange(r, STAT_START + 1).setFormula(`=COUNTIF(${rangeRef},"E")`);
    out.getRange(r, STAT_START + 2).setFormula(`=COUNTIF(${rangeRef},"N")+COUNTIF(${rangeRef},"N전")`);
    out.getRange(r, STAT_START + 3).setFormula(`=COUNTIF(${rangeRef},"/")`);

    {
      const bCol  = colToLetter(2);
      const nCell = `${statN}${r}`;
      if (nurse.type === NURSE_TYPE.NIGHT) {
        const target = RULES.NIGHT_TARGET[nurse.gender] || 14;
        out.getRange(r, 3).setFormula(`=${bCol}${r}+(${nCell}-${target})`);
      } else {
        out.getRange(r, 3).setFormula(`=${bCol}${r}+${baseOff}-${statO}${r}`);
      }
    }
  });

  _applyStylesOutput(out, nurses, nurseRows, totalDays, year, month, holidays);

  return out;
}

function _appendDailyCountRow(out, nurses, sched, totalDays) {}

function _appendDailyCountRowFormula(out, nurses, totalDays, nurseRows) {
  const DATE_COL  = 4;   
  const totalCols = 3 + totalDays + 6; 

  const targetRows = nurseRows
    .filter(r => !r.isFixed)
    .map(r => r.sheetRow);

  if (targetRows.length === 0) return;

  out.appendRow(['D 인원', '', '', ...new Array(totalDays + 6).fill('')]);
  out.appendRow(['E 인원', '', '', ...new Array(totalDays + 6).fill('')]);
  out.appendRow(['N 인원', '', '', ...new Array(totalDays + 6).fill('')]);

  const lastRow = out.getLastRow();
  const dRow = lastRow - 2;
  const eRow = lastRow - 1;
  const nRow = lastRow;

  for (let d = 0; d < totalDays; d++) {
    const col    = DATE_COL + d;
    const colLet = colToLetter(col);

    const sumD = targetRows.map(r => `COUNTIF(${colLet}${r},"D")`).join('+');
    const sumE = targetRows.map(r => `COUNTIF(${colLet}${r},"E")`).join('+');
    const sumN = targetRows.map(r => `COUNTIF(${colLet}${r},"N")+COUNTIF(${colLet}${r},"N전")`).join('+');

    out.getRange(dRow, col).setFormula(`=${sumD}`);
    out.getRange(eRow, col).setFormula(`=${sumE}`);
    out.getRange(nRow, col).setFormula(`=${sumN}`);
  }

  out.getRange(dRow, 1, 3, totalCols).setFontWeight('bold');
  out.getRange(dRow, 1, 1, totalCols).setBackground('#D4EDDA');
  out.getRange(eRow, 1, 1, totalCols).setBackground('#FFF3CD');
  out.getRange(nRow, 1, 1, totalCols).setBackground('#CCE5FF');
}

function _applyStylesOutput(out, nurses, nurseRows, totalDays, year, month, holidays) {
  const totalCols = 3 + totalDays + 6; 

  styleHeader(out.getRange(1, 1, 1, totalCols), '#2C5F8A');
  out.setFrozenRows(1);
  out.setFrozenColumns(1);

  for (let d = 1; d <= totalDays; d++) {
    const col  = d + 3;
    const cell = out.getRange(1, col);
    if (isWeekendOrHoliday(year, month, d, holidays)) {
      cell.setBackground('#555555').setFontColor('#FFFFFF');
    } else {
      cell.setBackground('#CCCCCC').setFontColor('#333333');
    }
  }

  const sheetData  = out.getDataRange().getValues();
  for (let i = 1; i < sheetData.length; i++) {
    const nm = normalize(sheetData[i][0]);
    if (nm.endsWith('팀')) {
      out.getRange(i + 1, 1, 1, totalCols).setBackground(null).setFontWeight('bold');
    }
  }

  out.setColumnWidth(1, 70);   
  out.setColumnWidth(2, 45);   
  out.setColumnWidth(3, 45);   
  for (let d = 4; d <= 3 + totalDays; d++) out.setColumnWidth(d, 30);           
  for (let c = 4 + totalDays; c <= totalCols - 1; c++) out.setColumnWidth(c, 45); 
  out.setColumnWidth(totalCols, 200);  
}

function _applyStylesResult(result, srcData, nurses, totalDays, year, month, holidays) {
  const totalCols = 3 + totalDays + 6; 
  const skipPfx   = ['D 인원', 'E 인원', 'N 인원'];

  styleHeader(result.getRange(1, 1, 1, totalCols), '#2C5F8A');
  result.setFrozenRows(1);
  result.setFrozenColumns(1);

  for (let d = 1; d <= totalDays; d++) {
    const col  = d + 3;
    const cell = result.getRange(1, col);
    if (isWeekendOrHoliday(year, month, d, holidays)) {
      cell.setBackground('#555555').setFontColor('#FFFFFF');
    } else {
      cell.setBackground('#CCCCCC').setFontColor('#333333');
    }
  }

  const nameToRow = {};
  for (let i = 1; i < srcData.length; i++) {
    const nm = normalize(srcData[i][0]);
    if (!nm || skipPfx.some(p => nm.startsWith(p))) continue;
    nameToRow[nm] = i + 1;  
  }

  for (let i = 1; i < srcData.length; i++) {
    const nm = normalize(srcData[i][0]);
    if (nm.endsWith('팀')) {
      result.getRange(i + 1, 1, 1, totalCols).setBackground(null).setFontColor(null).setFontWeight('bold');
    }
  }

  nurses.forEach(nurse => {
    const row = nameToRow[nurse.name];
    if (!row) return;
    for (let d = 0; d < totalDays; d++) {
      const duty  = normalize(srcData[row - 1][3 + d]);
      const color = DUTY_COLOR[duty] || '#FFFFFF';
      result.getRange(row, 4 + d).setBackground(color);
    }
  });

  result.setColumnWidth(1, 70);   
  result.setColumnWidth(2, 45);   
  result.setColumnWidth(3, 45);   
  for (let d = 4; d <= 3 + totalDays; d++) result.setColumnWidth(d, 30);            
  for (let c = 4 + totalDays; c <= totalCols - 1; c++) result.setColumnWidth(c, 45); 
  result.setColumnWidth(totalCols, 200);  
}

function _applyStyles() {}

function highlightViolations(out, nurses, sched, totalDays, prevHist, year, month, holidays) {
  const DATE_COL_OFFSET = 3; 
  const skipPrefixes    = ['D 인원', 'E 인원', 'N 인원'];

  SpreadsheetApp.flush(); 

  const dataRange = out.getDataRange();
  const sheetData = dataRange.getValues();
  const bgArray   = dataRange.getBackgrounds();
  const fcArray   = dataRange.getFontColors();
  const fwArray   = dataRange.getFontWeights();
  const totalRows = sheetData.length;

  const nameToRowIdx = {};
  for (let i = 1; i < totalRows; i++) {
    const cellName = normalize(sheetData[i][0]);
    if (!cellName) continue;
    if (cellName.endsWith('팀')) continue;
    if (skipPrefixes.some(p => cellName.startsWith(p))) continue;
    nameToRowIdx[cellName] = i;
  }

  let violCount = 0;

  nurses.forEach(nurse => {
    if (FIXED_AUTO_TYPES.has(nurse.type)) return;

    const ri = nameToRowIdx[nurse.name];
    if (ri === undefined) return;

    let consec = 0;

    for (let d = 0; d < totalDays; d++) {
      const cur = sched[nurse.idx][d] || '';

      if (!isAssigned(cur)) { consec = 0; continue; }

      let viol = false;

      if (d >= 1) {
        const prev1 = sched[nurse.idx][d - 1] || '';
        if (cur === DUTY.D && prev1 === DUTY.E)  viol = true;
        if (cur === DUTY.E && isNight(prev1))    viol = true;
        if (cur === DUTY.D && isNight(prev1))    viol = true;
        if (cur === DUTY.EDU_R && (prev1 === DUTY.E || isNight(prev1))) viol = true;  

        if (d >= 2) {
          const prev2 = sched[nurse.idx][d - 2] || '';
          if (cur === DUTY.D && (isOff(prev1) || isRecovery(prev1)) && isNight(prev2)) viol = true;
        }
      }

      if (isWork(cur)) {
        consec++;
        if (consec > RULES.MAX_CONSEC_WORK) viol = true;
      } else {
        consec = 0;
      }

      if (viol) {
        const ci = DATE_COL_OFFSET + d; 
        bgArray[ri][ci] = '#FF4444';
        fcArray[ri][ci] = '#FFFFFF';
        fwArray[ri][ci] = 'bold';
        violCount++;
      }
    }
  });

  const countRowIdx = { D: -1, E: -1, N: -1 };
  for (let i = 1; i < totalRows; i++) {
    const n = normalize(sheetData[i][0]);
    if (n === 'D 인원') countRowIdx[DUTY.D] = i;
    if (n === 'E 인원') countRowIdx[DUTY.E] = i;
    if (n === 'N 인원') countRowIdx[DUTY.N] = i;
  }

  for (let d = 0; d < totalDays; d++) {
    const counts = countGeneralStaff(sched, nurses, d);
    [DUTY.D, DUTY.E, DUTY.N].forEach(s => {
      const n  = counts[s] || 0;
      const ri = countRowIdx[s];
      if (ri === -1) return;
      if (n < RULES.MIN_STAFF[s] || n > RULES.MAX_STAFF[s]) {
        const ci = DATE_COL_OFFSET + d;
        bgArray[ri][ci] = '#FF4444';
        fcArray[ri][ci] = '#FFFFFF';
        fwArray[ri][ci] = 'bold';
        violCount++;
      }
    });
  }

  dataRange.setBackgrounds(bgArray);
  dataRange.setFontColors(fcArray);
  dataRange.setFontWeights(fwArray);

  log(`[Highlight] 위반 셀 ${violCount}개 표시 완료 (개인 전환/연속 + 인원 범위 포함)`);
}

function createResultSheet(ss, yyyymm, outSheet, nurses, totalDays) {
  const year   = parseInt(yyyymm.slice(0, 4), 10);
  const month  = parseInt(yyyymm.slice(4, 6), 10);
  const holidays = loadHolidays(ss, year, month);

  const resultName = SHEET.RESULT_PREFIX + yyyymm;
  const result     = recreateSheet(ss, resultName);

  const srcData = outSheet.getDataRange().getValues();
  const srcFw   = outSheet.getDataRange().getFontWeights();
  const totalRows = srcData.length;
  const totalCols = srcData[0].length;

  result.getRange(1, 1, totalRows, totalCols).setValues(srcData);
  result.getRange(1, 1, totalRows, totalCols).setFontWeights(srcFw);

  _applyStylesResult(result, srcData, nurses, totalDays, year, month, holidays);

  return resultName;
}


