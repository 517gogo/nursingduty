function getTargetYYYYMM(ss) {
  const sh = ss.getSheetByName(SHEET.HOLIDAYS);
  if (!sh) throw new Error("'설정' 시트가 없습니다.\n기본 시트 초기화를 먼저 실행해 주세요.");
  const val = normalize(sh.getRange('B1').getValue());
  if (!/^\d{6}$/.test(val)) {
    throw new Error("설정 시트 B1에 YYYYMM 형식으로 대상 월을 입력해 주세요.\n예: 202508");
  }
  return val;
}

function loadNurses(ss) {
  const sh = ss.getSheetByName(SHEET.NURSES);
  if (!sh) throw new Error(`'${SHEET.NURSES}' 시트를 찾을 수 없습니다.`);

  const data   = sh.getDataRange().getValues();
  const nurses = [];

  for (let i = 1; i < data.length; i++) {
    const row  = data[i];
    const name = normalize(row[COL_NURSE.NAME]);
    if (!name) continue;

    nurses.push({
      idx:         nurses.length,
      name,
      type:        normalize(row[COL_NURSE.TYPE]),
      gender:      normalize(row[COL_NURSE.GENDER]) || '여',
      team:        normalize(row[COL_NURSE.TEAM]),
      preceptor:   normalize(row[COL_NURSE.PRECEPTOR]),
      accumOff:   0,   
      monthWanted: 0,
    });
  }

  const invalidPreceptors = [];
  nurses.forEach(n => {
    if (n.type !== NURSE_TYPE.NEW || !n.preceptor) return;
    const prec = nurses.find(p => p.name === n.preceptor);
    if (prec && FIXED_AUTO_TYPES.has(prec.type)) {
      invalidPreceptors.push(`${n.name} (프리셉터: ${prec.name} / ${prec.type})`);
    }
  });
  if (invalidPreceptors.length > 0) {
    throw new Error(
      `❌ 프리셉터 설정 오류:\n수간호사/P-D/P-E는 프리셉터로 지정할 수 없습니다.\n\n` +
      `문제 간호사:\n${invalidPreceptors.join('\n')}`
    );
  }

  return nurses;
}

function loadHolidays(ss, year, month) {
  const sh  = ss.getSheetByName(SHEET.HOLIDAYS);
  const set = new Set();
  if (!sh) return set;

  const totalDays = new Date(year, month, 0).getDate();
  for (let i = 0; i < totalDays; i++) {
    const row     = SETTINGS_DAY_START_ROW + i;
    const checked = sh.getRange(row, 3).getValue(); 
    if (checked === true) set.add(i + 1);
  }
  return set;
}

function loadPrevHistory(ss, yyyymm, nurses) {
  const hist = {};
  nurses.forEach(n => { hist[n.idx] = new Array(7).fill(''); });

  const sh = ss.getSheetByName(SHEET.PREV_SCHED);
  if (!sh || sh.getLastRow() <= 1) return hist;

  const data = sh.getDataRange().getValues();

  const DATE_OFFSET = 3; 
  let prevTotalDays = 0;
  for (let c = DATE_OFFSET; c < data[0].length; c++) {
    const v = parseInt(normalize(data[0][c]), 10);
    if (!isNaN(v) && v > prevTotalDays) prevTotalDays = v;
    else if (!isNaN(v) && v < prevTotalDays) break; 
  }
  if (prevTotalDays === 0) return hist;

  const skipPrefixes = ['D 인원', 'E 인원', 'N 인원'];

  for (let i = 1; i < data.length; i++) {
    const name = normalize(data[i][0]);
    if (!name || name.endsWith('팀')) continue;
    if (skipPrefixes.some(p => name.startsWith(p))) continue;

    const nurse = nurses.find(n => n.name === name);
    if (!nurse) continue;

    const last7 = [];
    for (let d = prevTotalDays - 6; d <= prevTotalDays; d++) {
      const colIdx = DATE_OFFSET + (d - 1);
      last7.push(normalize(data[i][colIdx] || ''));
    }
    hist[nurse.idx] = last7;
  }

  return hist;
}

function loadPrevAccumData(ss, yyyymm, nurses) {
  const sh = ss.getSheetByName(SHEET.PREV_SCHED);
  if (!sh || sh.getLastRow() <= 1) return; 

  const data        = sh.getDataRange().getValues();
  const skipNames   = ['D 인원', 'E 인원', 'N 인원'];

  for (let i = 1; i < data.length; i++) {
    const name = normalize(data[i][0]);
    if (!name || name.endsWith('팀') || skipNames.some(p => name.startsWith(p))) continue;

    const nurse = nurses.find(n => n.name === name);
    if (!nurse) continue;

    const rawOff = parseFloat(normalize(data[i][2]));
    if (!isNaN(rawOff)) nurse.accumOff = rawOff;
  }
}

function loadFixedDuty(ss, yyyymm) {
  const sh     = ss.getSheetByName(SHEET.FIXED);
  const result = {};
  if (!sh || sh.getLastRow() <= 1) return result;

  const data      = sh.getDataRange().getValues();
  const totalDays = getTotalDays(yyyymm);

  for (let i = 1; i < data.length; i++) {
    const name = normalize(data[i][0]);
    if (!name) continue;
    result[name] = {};

    for (let d = 1; d <= totalDays; d++) {
      const val = normalize(data[i][d]); 
      if (val) result[name][d] = val;
    }
  }

  return result;
}

function loadWanted(ss, yyyymm, nurses) {
  const sh   = ss.getSheetByName(SHEET.WANTED);
  const reqs = [];
  if (!sh || sh.getLastRow() <= 1) return reqs;

  const data      = sh.getDataRange().getValues();
  const totalDays = getTotalDays(yyyymm);

  for (let i = 1; i < data.length; i++) {
    const name = normalize(data[i][0]);
    if (!name) continue;

    const nurse = nurses.find(n => n.name === name);
    if (!nurse) continue;

    for (let slot = 0; slot < 5; slot++) {
      const dayVal   = normalize(data[i][1 + slot * 2]);
      const wtypeVal = normalize(data[i][2 + slot * 2]);
      if (!dayVal || !wtypeVal) continue;

      const day = parseInt(dayVal, 10);
      if (isNaN(day) || day < 1 || day > totalDays) continue;

      if (nurse.type === NURSE_TYPE.NIGHT && !NIGHT_ALLOWED_WANTED.has(wtypeVal)) continue;

      let primaryWtype = wtypeVal, fallbackWtype = null;
      const orMatch = wtypeVal.match(/^(.+?)\s+or\s+(.+)$/i);
      if (orMatch) {
        primaryWtype  = normalize(orMatch[1]);
        fallbackWtype = normalize(orMatch[2]);
      }

      const priority = WANTED_PRIORITY[primaryWtype] ?? WANTED_PRIORITY[fallbackWtype];
      if (priority === undefined) continue;

      reqs.push({ nurse, day, wtype: primaryWtype, fallbackWtype, priority });
      nurse.monthWanted++;
    }
  }

  reqs.sort((a, b) =>
    a.priority !== b.priority ? a.priority - b.priority : a.day - b.day
  );

  return reqs;
}

function readScheduleFromSheet(sheet, nurses, totalDays) {
  const sched      = nurses.map(() => new Array(totalDays).fill(''));
  const data       = sheet.getDataRange().getValues();
  const DATE_OFFSET = 3; 

  const skipPrefixes = ['D 인원', 'E 인원', 'N 인원'];

  for (let i = 1; i < data.length; i++) {
    const name = normalize(data[i][0]);
    if (!name) continue;
    if (name.endsWith('팀')) continue;
    if (skipPrefixes.some(p => name.startsWith(p))) continue;

    const nurse = nurses.find(n => n.name === name);
    if (!nurse) continue;

    for (let d = 0; d < totalDays; d++) {
      sched[nurse.idx][d] = normalize(data[i][DATE_OFFSET + d]) || '';
    }
  }

  return sched;
}


/**
 * ============================================================
 * RuleChecker.gs — 전환 규칙 / 연속근무 / 주간근무 검증
 * ============================================================
 */

function checkTransition(sched, nurseIdx, d, newDuty, prevHist, totalDays) {
  const prev1 = getSlot(sched, nurseIdx, d - 1, prevHist, totalDays);
  if (prev1 === '') return true;

  const forbidden = FORBIDDEN_PREV[newDuty];
  if (forbidden && forbidden.has(prev1)) return false;

  if ((newDuty === DUTY.D || newDuty === DUTY.D9 || newDuty === DUTY.D10) && (isOff(prev1) || isRecovery(prev1))) {
    let offCount = 1;
    for (let i = d - 2; i >= d - 10; i--) {
      const past = getSlot(sched, nurseIdx, i, prevHist, totalDays);
      if (past === '') break;
      if (isOff(past) || isRecovery(past)) {
        offCount++;
      } else if (isNight(past)) {
        if (offCount === 1) return false;
        break;
      } else {
        break;
      }
    }
  }

  return true;
}

function checkConsecutiveWork(sched, nurseIdx, d, prevHist, totalDays) {
  let consec = 0;
  for (let i = d - 1; i >= d - RULES.MAX_CONSEC_WORK; i--) {
    const past = getSlot(sched, nurseIdx, i, prevHist, totalDays);
    if (past === '') break;
    if (isWork(past)) consec++;
    else break;
  }
  return consec < RULES.MAX_CONSEC_WORK;
}

function checkWeeklyWork(sched, nurseIdx, d, prevHist, totalDays, year, month) {
  const date = new Date(year, month - 1, d + 1);
  const dow  = date.getDay();
  const mondayOffset = dow === 0 ? -6 : -(dow - 1);

  let weekWork = 0;
  for (let offset = mondayOffset; offset < mondayOffset + 7; offset++) {
    if (offset === 0) continue;
    const checkD = d + offset;
    const duty   = getSlot(sched, nurseIdx, checkD, prevHist, totalDays);
    if (isWork(duty)) weekWork++;
  }
  return weekWork < RULES.MAX_WEEK_WORK;
}

function checkForwardTransition(sched, nurseIdx, d, newDuty, prevHist, totalDays) {
  const next = getSlot(sched, nurseIdx, d + 1, prevHist, totalDays);
  if (!next || next === '') return true;

  const forbiddenPrev = FORBIDDEN_PREV[next];
  if (forbiddenPrev && forbiddenPrev.has(newDuty)) return false;

  if (isNight(newDuty)) {
    const next2 = getSlot(sched, nurseIdx, d + 2, prevHist, totalDays);
    if (next2 === '') return true;
    let offCount = 0;
    for (let i = d + 1; i < totalDays; i++) {
      const v = getSlot(sched, nurseIdx, i, prevHist, totalDays);
      if (v === '') break;
      if (isOff(v) || isRecovery(v)) offCount++;
      else {
        if (v === DUTY.D && offCount === 1) return false;
        break;
      }
    }
  }

  return true;
}

function canAssignWork(sched, nurseIdx, d, duty, prevHist, totalDays, year, month) {
  if (!checkTransition(sched, nurseIdx, d, duty, prevHist, totalDays))        return false;
  if (!checkForwardTransition(sched, nurseIdx, d, duty, prevHist, totalDays)) return false;
  if (!checkConsecutiveWork(sched, nurseIdx, d, prevHist, totalDays))          return false;
  if (!checkWeeklyWork(sched, nurseIdx, d, prevHist, totalDays, year, month)) return false;
  return true;
}

function canAssignOff(sched, nurseIdx, d, duty, prevHist, totalDays) {
  if (!checkTransition(sched, nurseIdx, d, duty, prevHist, totalDays))        return false;
  if (!checkForwardTransition(sched, nurseIdx, d, duty, prevHist, totalDays)) return false;
  return true;
}

function countGeneralStaff(sched, nurses, d) {
  const counts = { D: 0, E: 0, N: 0 };
  nurses
    .filter(n =>
      n.type === NURSE_TYPE.GENERAL ||
      n.type === NURSE_TYPE.NEW     ||
      n.type === NURSE_TYPE.NIGHT     
    )
    .forEach(n => {
      const duty = sched[n.idx][d] || '';
      if (duty === DUTY.D)                    counts.D++;
      else if (duty === DUTY.E)               counts.E++;
      else if (duty === DUTY.N || duty === DUTY.N_FULL) counts.N++; 
    });
  return counts;
}

function countTeamStaff(sched, nurses, team, d) {
  const counts = { D: 0, E: 0 };
  nurses
    .filter(n => n.team === team &&
      (n.type === NURSE_TYPE.GENERAL || n.type === NURSE_TYPE.NEW))
    .forEach(n => {
      const duty = sched[n.idx][d] || '';
      if (duty === DUTY.D) counts.D++;
      else if (duty === DUTY.E) counts.E++;
    });
  return counts;
}

function getTeams(nurses) {
  return [...new Set(
    nurses
      .filter(n => n.team && (n.type === NURSE_TYPE.GENERAL || n.type === NURSE_TYPE.NEW))
      .map(n => n.team)
  )];
}

function countMonthlyNights(sched, nurseIdx, totalDays) {
  let count = 0;
  for (let d = 0; d < totalDays; d++) {
    if (isNight(sched[nurseIdx][d])) count++;
  }
  return count;
}

function isAssigned(duty) {
  return duty !== '' && duty !== null && duty !== undefined;
}


